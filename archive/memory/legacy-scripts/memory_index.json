{
  "version": "4.0",
  "updated_at": "2026-03-17T10:22:00+08:00",
  "description": "统一记忆系统索引文件（SQLite 主库 + 豆包向量层）",
  "source_of_truth": {
    "kind": "sqlite",
    "path": "memory/database/optimized_memory.db"
  },
  "write_path": {
    "primary": "memory/unified_memory.py",
    "compatibility_backup": [
      "memory/working/session_current.json",
      "memory/episodic/YYYY-MM-DD.jsonl",
      "memory/semantic/*.json"
    ]
  },
  "query_path": {
    "primary": "memory/memory_search.py",
    "semantic": "memory/vector_memory.py"
  },
  "vector_layer": {
    "provider": "doubao",
    "model": "doubao-embedding-vision-251215",
    "endpoint": "https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal",
    "table": "memory_vectors"
  },
  "main_tables": [
    "episodes",
    "knowledge",
    "conversation_summaries",
    "user_profile",
    "memory_vectors"
  ],
  "query_guide": {
    "刚才/现在": "working -> session_current.json",
    "今天/本周": "episodes (SQLite)",
    "用户偏好": "knowledge / user_profile (SQLite)",
    "语义相似问题": "memory_vectors (doubao embedding)",
    "历史总结": "conversation_summaries (SQLite)"
  }
}
